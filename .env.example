# -------------------------
# CLOUD AI PROVIDER API KEYS (BYOK)
# -------------------------
# Add your API keys here to enable cloud providers.
# The application will securely handle these keys.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
COHERE_API_KEY=""
OPENROUTER_API_KEY=""

# -------------------------
# LOCAL AI (OLLAMA)
# -------------------------
# The base URL for your running Ollama instance.
# Default is for a local installation.
OLLAMA_HOST="http://localhost:11434"

# -------------------------
# APPLICATION SECURITY
# -------------------------
# A secret key for encrypting sensitive data like API keys.
# Generate a strong key using: openssl rand -hex 32
APP_SECRET_KEY="change-this-to-a-strong-random-string"